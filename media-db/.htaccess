# data.json（顧客データ・パスワード）と設定ファイルへの直アクセスを禁止する。
# ブラウザから直接 URL を叩いても中身が見えないようにする（PHP経由のみ読み書き）。
<FilesMatch "(^|/)(data\.json|cost_cache\.json|config\.local\.php(\.example)?|exclude_domains\.txt|exclude_keywords\.txt|activity\.log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
